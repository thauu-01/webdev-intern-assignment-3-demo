
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Option 1 - SRV format (standard, may fail if ISP blocks DNS SRV lookups):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/g_scores?retryWrites=true&w=majority&appName=Cluster0
# Option 2 - Direct replica set (use if SRV fails - get hosts from Atlas UI > Connect):
MONGODB_URI=mongodb://<username>:<password>@<shard-00-00>:27017,<shard-00-01>:27017,<shard-00-02>:27017/g_scores?replicaSet=<replicaSetName>&ssl=true&authSource=admin&retryWrites=true&w=majority


CORS_ORIGINS=http://localhost:5173,http://localhost:3000

CSV_PATH=../dataset/diem_thi_thpt_2024.csv

SEED_BATCH_SIZE=1000
